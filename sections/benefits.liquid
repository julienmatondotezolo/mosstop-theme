<section class="section section-padding">
  <div class="page-width text-center">
    <span class="text-overline text-primary" style="display: block; margin-bottom: var(--space-sm);">{{ 'benefits.overline' | t | default: 'Waarom wij' }}</span>
    <h2 class="text-h2 mb-lg reveal">{{ section.settings.heading }}</h2>

    <div class="trust-badges stagger">
      {%- for block in section.blocks -%}
        <div class="trust-badge reveal" {{ block.shopify_attributes }} style="--reveal-delay: {{ forloop.index0 | times: 150 }}ms;">
          <div class="trust-badge-icon">
            {% render 'icon', name: block.settings.icon, size: 24 %}
          </div>
          <strong class="trust-badge-label">{{ block.settings.title }}</strong>
          {%- if block.settings.text != blank -%}
            <p class="text-body-sm text-secondary" style="margin-top: var(--space-xs); max-width: 240px;">{{ block.settings.text }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

    <hr class="divider" style="margin-top: var(--space-2xl);">

    {% render 'trust-certifications' %}
  </div>
</section>

{% schema %}
{
  "name": "Benefits",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Waarom Mosstop?"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "leaf", "label": "Leaf" },
            { "value": "shield", "label": "Shield" },
            { "value": "clock", "label": "Clock" },
            { "value": "truck", "label": "Truck" }
          ],
          "default": "leaf"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "100% Natuurlijk"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Alleen de zuiverste ingrediënten uit de natuur."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Benefits",
      "blocks": [
        { "type": "benefit", "settings": { "icon": "leaf", "title": "100% Natuurlijk", "text": "Alleen de zuiverste ingrediënten uit de natuur." } },
        { "type": "benefit", "settings": { "icon": "shield", "title": "Dermatologisch getest", "text": "Veilig en geschikt voor elke huidtype." } },
        { "type": "benefit", "settings": { "icon": "truck", "title": "Snelle levering", "text": "Gratis verzending vanaf €50 in België." } },
        { "type": "benefit", "settings": { "icon": "clock", "title": "Duurzaam verpakt", "text": "Recyclebare materialen, minimale afval." } }
      ]
    }
  ]
}
{% endschema %}
