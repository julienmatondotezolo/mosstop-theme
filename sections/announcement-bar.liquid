{%- if section.settings.show -%}
  <div class="trust-bar" role="region" aria-label="Trust information">
    <div class="page-width trust-bar__inner">
      <span class="trust-bar__item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        {{ section.settings.trust_1 | default: 'Veilig Betalen' }}
      </span>
      <span class="trust-bar__separator" aria-hidden="true"></span>
      <span class="trust-bar__item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        {{ section.settings.trust_2 | default: 'Gratis Verzending €50+' }}
      </span>
      <span class="trust-bar__separator" aria-hidden="true"></span>
      <span class="trust-bar__item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="var(--accent-warm)" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        {{ section.settings.trust_3 | default: '4.8/5 Sterren' }}
      </span>
      <span class="trust-bar__separator hide-mobile" aria-hidden="true"></span>
      <span class="trust-bar__item hide-mobile">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        {{ section.settings.trust_4 | default: 'Nederlandse Klantenservice' }}
      </span>
    </div>
  </div>
{%- endif -%}

<style>
  .trust-bar {
    background: var(--green-700);
    color: var(--white);
    padding: 10px var(--space-md);
    font-size: 12px;
    font-weight: var(--weight-medium);
    letter-spacing: 0.02em;
  }

  .trust-bar__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-lg);
    flex-wrap: wrap;
  }

  .trust-bar__item {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    white-space: nowrap;
  }

  .trust-bar__separator {
    width: 1px;
    height: 12px;
    background: rgba(255, 255, 255, 0.3);
  }

  @media (max-width: 768px) {
    .trust-bar__inner {
      gap: var(--space-md);
    }
    .trust-bar__separator {
      display: none;
    }
    .trust-bar {
      font-size: 11px;
    }
  }
</style>

{% schema %}
{
  "name": "Trust bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "show",
      "label": "Show trust bar",
      "default": true
    },
    {
      "type": "text",
      "id": "trust_1",
      "label": "Trust item 1",
      "default": "Veilig Betalen"
    },
    {
      "type": "text",
      "id": "trust_2",
      "label": "Trust item 2",
      "default": "Gratis Verzending €50+"
    },
    {
      "type": "text",
      "id": "trust_3",
      "label": "Trust item 3",
      "default": "4.8/5 Sterren"
    },
    {
      "type": "text",
      "id": "trust_4",
      "label": "Trust item 4",
      "default": "Nederlandse Klantenservice"
    }
  ],
  "presets": [
    {
      "name": "Trust bar"
    }
  ]
}
{% endschema %}
