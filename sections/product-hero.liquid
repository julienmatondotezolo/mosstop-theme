{{ 'section-hero.css' | asset_url | stylesheet_tag }}

<section class="section bg-green-50 section-padding">
  <div class="page-width">
    <div class="product-hero">
      <div class="product-hero__image reveal">
        {%- if section.settings.product != blank and section.settings.product.featured_image -%}
          <img
            src="{{ section.settings.product.featured_image | image_url: width: 800 }}"
            alt="{{ section.settings.product.featured_image.alt | default: section.settings.product.title }}"
            width="800"
            height="800"
            loading="lazy"
          >
        {%- elsif section.settings.image != blank -%}
          <img
            src="{{ section.settings.image | image_url: width: 800 }}"
            alt="{{ section.settings.image.alt | default: section.settings.heading }}"
            width="800"
            height="800"
            loading="lazy"
          >
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>

      <div class="product-hero__content reveal">
        {%- if section.settings.badge != blank -%}
          <span class="badge">{{ section.settings.badge }}</span>
        {%- endif -%}
        <h2 class="text-h1">{{ section.settings.heading | default: section.settings.product.title }}</h2>
        <p class="text-body-lg text-secondary">{{ section.settings.text | default: section.settings.product.description | strip_html | truncate: 200 }}</p>

        {%- if section.settings.product != blank -%}
          <div class="product-hero__price">{{ section.settings.product.price | money }}</div>
          <a href="{{ section.settings.product.url }}" class="btn btn-primary">{{ 'product.view' | t }}</a>
        {%- elsif section.settings.cta_url != blank -%}
          <a href="{{ section.settings.cta_url }}" class="btn btn-primary">{{ section.settings.cta_text }}</a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product hero",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Featured product"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image (fallback if no product)"
    },
    {
      "type": "text",
      "id": "badge",
      "label": "Badge text"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Ons bestverkochte product"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button text",
      "default": "Ontdek nu"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Product hero"
    }
  ]
}
{% endschema %}
