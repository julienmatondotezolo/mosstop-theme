<section class="cta-banner section section-padding" style="position: relative; overflow: hidden;">
  {%- comment -%} Animated gradient background {%- endcomment -%}
  <div class="cta-banner__bg" aria-hidden="true"></div>

  {%- comment -%} Decorative leaves {%- endcomment -%}
  <div class="cta-banner__leaf cta-banner__leaf--1" aria-hidden="true">
    <svg width="100" height="100" viewBox="0 0 24 24" fill="currentColor" stroke="none" opacity="0.1">
      <path d="M17 8C8 10 5.9 16.17 3.82 21.34l1.89.66.95-2.3c.48.17.98.3 1.34.3C19 20 22 3 22 3c-1 2-8 2.25-13 3.25S2 11.5 2 13.5s1.75 3.75 1.75 3.75C7 8 17 8 17 8z"/>
    </svg>
  </div>
  <div class="cta-banner__leaf cta-banner__leaf--2" aria-hidden="true">
    <svg width="60" height="60" viewBox="0 0 24 24" fill="currentColor" stroke="none" opacity="0.08">
      <path d="M17 8C8 10 5.9 16.17 3.82 21.34l1.89.66.95-2.3c.48.17.98.3 1.34.3C19 20 22 3 22 3c-1 2-8 2.25-13 3.25S2 11.5 2 13.5s1.75 3.75 1.75 3.75C7 8 17 8 17 8z"/>
    </svg>
  </div>

  <div class="page-width" style="position: relative; z-index: 1;">
    <div class="cta-banner__card card-glass reveal" style="max-width: 640px; margin-inline: auto; text-align: center;">
      <h2 class="text-h2" style="color: var(--white); margin-bottom: var(--space-md);">{{ section.settings.heading }}</h2>
      <p class="text-body-lg" style="color: rgba(255,255,255,0.85); margin-bottom: var(--space-xl); max-width: 480px; margin-inline: auto;">{{ section.settings.text }}</p>
      {%- if section.settings.button_url != blank -%}
        <a href="{{ section.settings.button_url }}" class="btn btn-primary" style="background: var(--white); color: var(--green-700); border-color: var(--white);">
          {{ section.settings.button_text }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  .cta-banner__bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #2D4A3A, #1E3A2B, #3D6B52);
    background-size: 200% 200%;
    animation: ctaGradient 8s ease-in-out infinite;
  }

  @keyframes ctaGradient {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  .cta-banner__leaf {
    position: absolute;
    color: var(--white);
    z-index: 0;
  }

  .cta-banner__leaf--1 {
    top: 10%;
    left: 5%;
  }

  .cta-banner__leaf--2 {
    bottom: 10%;
    right: 8%;
    transform: rotate(45deg);
  }
</style>

{% schema %}
{
  "name": "CTA banner",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Klaar om te ontdekken?"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Probeer Mosstop vandaag nog en voel het verschil."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop nu"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "CTA banner"
    }
  ]
}
{% endschema %}
