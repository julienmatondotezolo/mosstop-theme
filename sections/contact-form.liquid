<section class="section section-padding">
  <div class="page-width" style="max-width: 640px;">
    <div class="text-center mb-lg reveal">
      <h1 class="text-h1">{%- if section.settings.heading != blank -%}{{ section.settings.heading }}{%- else -%}{{ 'contact.heading' | t }}{%- endif -%}</h1>
      <p class="text-body-lg text-secondary mt-md">{%- if section.settings.text != blank -%}{{ section.settings.text }}{%- else -%}{{ 'contact.text' | t }}{%- endif -%}</p>
    </div>

    {%- form 'contact', id: 'contact-form' -%}
      {%- if form.posted_successfully? -%}
        <div class="badge" style="display: block; text-align: center; padding: var(--space-md); margin-bottom: var(--space-lg);">
          {{ 'contact.success' | t }}
        </div>
      {%- endif -%}

      {%- if form.errors -%}
        <div class="badge badge-error" style="display: block; text-align: center; padding: var(--space-md); margin-bottom: var(--space-lg);">
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}

      <div class="reveal" style="display: flex; flex-direction: column; gap: var(--space-md);">
        <div>
          <label for="contact-name" class="text-body-sm" style="display: block; margin-bottom: var(--space-xs);">{{ 'contact.name' | t }}</label>
          <input type="text" name="contact[name]" id="contact-name" class="input" required autocomplete="name">
        </div>
        <div>
          <label for="contact-email" class="text-body-sm" style="display: block; margin-bottom: var(--space-xs);">{{ 'contact.email' | t }}</label>
          <input type="email" name="contact[email]" id="contact-email" class="input" required autocomplete="email">
        </div>
        <div>
          <label for="contact-message" class="text-body-sm" style="display: block; margin-bottom: var(--space-xs);">{{ 'contact.message' | t }}</label>
          <textarea name="contact[body]" id="contact-message" class="input" rows="6" required></textarea>
        </div>
        <button type="submit" class="btn btn-primary">{{ 'contact.send' | t }}</button>
      </div>
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "Contact form",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text"
    }
  ],
  "presets": [
    {
      "name": "Contact form"
    }
  ]
}
{% endschema %}
