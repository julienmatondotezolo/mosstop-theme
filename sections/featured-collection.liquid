<section class="section section-padding bg-green-50">
  <div class="page-width">
    <h2 class="text-h2 text-center mb-lg reveal">{{ section.settings.heading }}</h2>

    {%- if section.settings.collection != blank -%}
      <div class="grid grid-4">
        {%- for product in section.settings.collection.products limit: section.settings.limit -%}
          <div class="reveal">
            {% render 'product-card', product: product %}
          </div>
        {%- endfor -%}
      </div>

      {%- if section.settings.show_view_all -%}
        <div class="text-center mt-lg">
          <a href="{{ section.settings.collection.url }}" class="btn btn-secondary">{{ 'collection.all' | t }}</a>
        </div>
      {%- endif -%}
    {%- else -%}
      <div class="grid grid-4">
        {%- for i in (1..4) -%}
          <div class="card" style="padding: var(--space-lg); text-align: center;">
            {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Onze producten"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "limit",
      "label": "Number of products",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'View all' button",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Featured collection"
    }
  ]
}
{% endschema %}
