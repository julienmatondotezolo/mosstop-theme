<section class="section section-padding bg-green-50">
  <div class="page-width text-center">
    <span class="text-overline text-primary" style="display: block; margin-bottom: var(--space-sm);">{{ 'how_it_works.overline' | t | default: 'Simpel & effectief' }}</span>
    <h2 class="text-h2 mb-lg reveal">{{ section.settings.heading }}</h2>

    <div class="how-it-works__steps" style="display: flex; justify-content: center; gap: var(--space-3xl); max-width: 960px; margin-inline: auto; position: relative;">
      {%- for block in section.blocks -%}
        <div class="reveal" {{ block.shopify_attributes }} style="display: flex; flex-direction: column; align-items: center; gap: var(--space-md); flex: 1; position: relative; --reveal-delay: {{ forloop.index0 | times: 200 }}ms;">
          {%- comment -%} Connecting line between steps {%- endcomment -%}
          {%- unless forloop.last -%}
            <div style="
              position: absolute;
              top: 36px;
              left: calc(50% + 40px);
              width: calc(100% - 16px);
              height: 2px;
              background: linear-gradient(90deg, var(--green-300), var(--green-100));
              z-index: 0;
            " class="hide-mobile" aria-hidden="true"></div>
          {%- endunless -%}
          <div style="
            width: 72px; height: 72px;
            border-radius: var(--radius-full);
            background: var(--green-700);
            color: var(--white);
            display: flex; align-items: center; justify-content: center;
            font-size: 28px;
            font-weight: var(--weight-bold);
            position: relative;
            z-index: 1;
            box-shadow: 0 4px 16px rgba(45, 74, 58, 0.25);
          ">{{ forloop.index }}</div>
          <h3 class="text-h4">{{ block.settings.title }}</h3>
          <p class="text-body-sm text-secondary" style="max-width: 260px; line-height: 1.6;">{{ block.settings.text }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  @media (max-width: 768px) {
    .how-it-works__steps {
      flex-direction: column !important;
      gap: var(--space-xl) !important;
    }
  }
</style>

{% schema %}
{
  "name": "How it works",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Hoe werkt het?"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Stap"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "How it works",
      "blocks": [
        { "type": "step", "settings": { "title": "Kies je product", "text": "Bekijk ons assortiment en vind de perfecte verzorging." } },
        { "type": "step", "settings": { "title": "Bestel online", "text": "Veilig betalen en snel geleverd aan huis." } },
        { "type": "step", "settings": { "title": "Geniet van resultaat", "text": "Ervaar de kracht van mos op je huid." } }
      ]
    }
  ]
}
{% endschema %}
