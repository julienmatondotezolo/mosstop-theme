{% layout 'theme' %}

<section class="section section-padding">
  <div class="page-width" style="max-width: 480px;">
    <h1 class="text-h1 text-center mb-lg">{{ 'customer.register.title' | t }}</h1>
    {%- form 'create_customer' -%}
      {{ form.errors | default_errors }}
      <div style="display: flex; flex-direction: column; gap: var(--space-md);">
        <div>
          <label for="first-name" class="text-body-sm" style="display: block; margin-bottom: var(--space-xs);">{{ 'customer.register.first_name' | t }}</label>
          <input type="text" name="customer[first_name]" id="first-name" class="input" autocomplete="given-name">
        </div>
        <div>
          <label for="last-name" class="text-body-sm" style="display: block; margin-bottom: var(--space-xs);">{{ 'customer.register.last_name' | t }}</label>
          <input type="text" name="customer[last_name]" id="last-name" class="input" autocomplete="family-name">
        </div>
        <div>
          <label for="email" class="text-body-sm" style="display: block; margin-bottom: var(--space-xs);">{{ 'customer.register.email' | t }}</label>
          <input type="email" name="customer[email]" id="email" class="input" required autocomplete="email">
        </div>
        <div>
          <label for="password" class="text-body-sm" style="display: block; margin-bottom: var(--space-xs);">{{ 'customer.register.password' | t }}</label>
          <input type="password" name="customer[password]" id="password" class="input" required>
        </div>
        <button type="submit" class="btn btn-primary">{{ 'customer.register.submit' | t }}</button>
      </div>
    {%- endform -%}
  </div>
</section>
