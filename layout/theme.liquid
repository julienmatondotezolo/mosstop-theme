<!doctype html>
<html lang="{{ localization.language.iso_code }}" dir="ltr">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="{{ settings.color_primary | default: '#2D4A3A' }}">

  <title>
    {%- if page_title -%}{{ page_title }} – {{ shop.name }}{%- else -%}{{ shop.name }}{%- endif -%}
  </title>

  {% render 'seo-meta' %}

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32 }}">
  {%- endif -%}

  {%- comment -%} Fonts — Inter via Google Fonts link tag for performance {%- endcomment -%}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Montserrat:wght@500;600;700;800&family=Playfair+Display:ital,wght@0,500;0,700;1,500&display=swap" rel="stylesheet">

  {%- comment -%} CSS load order: tokens → typography → components → base {%- endcomment -%}
  {{ 'design-tokens.css' | asset_url | stylesheet_tag }}
  {{ 'typography.css' | asset_url | stylesheet_tag }}
  {{ 'components.css' | asset_url | stylesheet_tag }}
  {{ 'base.css' | asset_url | stylesheet_tag }}

  {{ content_for_header }}
</head>
<body class="template-{{ template.name | default: 'other' }}">
  <div class="scroll-progress" aria-hidden="true"></div>
  <a href="#main-content" class="skip-to-content">{{ 'general.skip_to_content' | t }}</a>

  {% section 'announcement-bar' %}
  {% section 'header' %}

  <main id="main-content" role="main">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  {% render 'sticky-buy-bar' %}

  <script src="{{ 'theme.js' | asset_url }}" defer></script>
</body>
</html>
