{%- comment -%}
  Usage: {% render 'quantity-selector', id: 'qty-1', value: 1, name: 'quantity' %}
{%- endcomment -%}

<div class="quantity-selector" data-qty style="
  display: inline-flex;
  align-items: center;
  border: 1px solid var(--neutral-300);
  border-radius: var(--radius-md);
  overflow: hidden;
">
  <button
    type="button"
    data-qty-btn="minus"
    aria-label="{{ 'accessibility.decrease_quantity' | t }}"
    style="
      width: 40px; height: 40px;
      display: flex; align-items: center; justify-content: center;
      color: var(--neutral-700);
    "
  >
    {% render 'icon', name: 'minus', size: 16 %}
  </button>
  <input
    type="number"
    name="{{ name | default: 'quantity' }}"
    id="{{ id | default: 'quantity' }}"
    value="{{ value | default: 1 }}"
    min="1"
    max="99"
    aria-label="{{ 'product.quantity' | t }}"
    {% if cart_key %}data-cart-qty="{{ cart_key }}"{% endif %}
    style="
      width: 48px; height: 40px;
      text-align: center;
      border: none;
      border-left: 1px solid var(--neutral-300);
      border-right: 1px solid var(--neutral-300);
      font-size: var(--font-size-body);
      -moz-appearance: textfield;
    "
  >
  <button
    type="button"
    data-qty-btn="plus"
    aria-label="{{ 'accessibility.increase_quantity' | t }}"
    style="
      width: 40px; height: 40px;
      display: flex; align-items: center; justify-content: center;
      color: var(--neutral-700);
    "
  >
    {% render 'icon', name: 'plus', size: 16 %}
  </button>
</div>
